set name = man2

all.role manager
all.manager meta localhost:%CMSD_PORT_METAMAN%
all.manager localhost:%CMSD_PORT_MAN2%

xrd.port %XRD_PORT_MAN2% if exec xrootd
xrd.port %CMSD_PORT_MAN2% if exec cmsd

if exec xrootd
xrd.protocol XrdHttp:%XRD_PORT_MAN2% libXrdHttp.so
fi

continue @CMAKE_CURRENT_BINARY_DIR@/common.cfg
